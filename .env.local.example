# Copy this file to .env.local and fill in your own values.

# --- Supabase ---
# Get these from https://app.supabase.com -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# --- Google Maps / Places ---
# Get from https://console.cloud.google.com/google/maps-apis
# Enable: Maps JavaScript API, Places API (New)
# IMPORTANT: Restrict the key by HTTP referrer (localhost + your prod domain)
# and set a daily quota cap to stay within the free tier.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=YOUR-MAPS-KEY
